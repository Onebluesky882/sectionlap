# Copy this file to .env and fill in secrets before running
# (run ./gen-passwords.sh to generate the *_PASSWORD / *_SECRET values)

CONFIG=~/.jitsi-meet-cfg
TZ=UTC

# --- Ports ---
HTTP_PORT=8000
HTTPS_PORT=8443
JVB_TCP_PORT=4443
JVB_UDP_PORT=10000

# --- Public URL (local dev) ---
PUBLIC_URL=http://localhost:8000

# --- HTTPS (disabled for local dev) ---
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=1
ENABLE_LETSENCRYPT=0
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=

# --- Auth / Guests ---
# No login required for local dev — anyone with the room URL can join
ENABLE_AUTH=0
ENABLE_GUESTS=1
AUTH_TYPE=internal

# --- XMPP domains ---
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_BOSH_URL_BASE=http://xmpp.meet.jitsi:5280
XMPP_CROSS_DOMAIN=true
XMPP_MODULES=
XMPP_MUC_MODULES=
XMPP_INTERNAL_MUC_MODULES=

# --- JVB / Jicofo internal auth (generate via gen-passwords.sh) ---
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=
JICOFO_AUTH_USER=focus
JICOFO_AUTH_PASSWORD=
JICOFO_COMPONENT_SECRET=

JVB_BREWERY_MUC=jvbbrewery
JIGASI_BREWERY_MUC=jigasibrewery
JIBRI_BREWERY_MUC=jibribrewery
JIBRI_PENDING_TIMEOUT=90

