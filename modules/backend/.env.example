# SectionLap Backend — Environment Variables
# Copy this file to .env and fill in your values.

# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sectionlap?sslmode=disable

# Auth secret — min 32 chars, random, kept secret
AUTH_SECRET=changeme-use-a-long-random-string-here

# Session
SESSION_HOURS=24

# Jitsi Meet (from modules/live-class setup)
JITSI_APP_ID=sectionlap
JITSI_APP_SECRET=changeme-jitsi-secret
JITSI_DOMAIN=localhost

# Claude (AI parse) — leave empty to use mockParse (no subscription needed)
CLAUDE_API_KEY=

# Visual Plan Service (Python renderer)
VISUAL_SERVICE_URL=http://localhost:9000

# Cloudflare R2 (presigned GET URLs for generated GIF/MP4)
# Create the Access Key ID / Secret via the Cloudflare dashboard:
# R2 > Manage R2 API Tokens > Create API token (Object Read & Write, scoped to this bucket)
R2_ENDPOINT=https://c40a6cc1eb575a43f79e9b4d9cc6a88d.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sectionlap-bucket
