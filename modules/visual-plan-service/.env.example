R2_ENDPOINT=https://c40a6cc1eb575a43f79e9b4d9cc6a88d.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=sectionlap-bucket
# Bucket is private (no custom domain) — this fallback URL won't resolve.
# The Go backend re-presigns GET URLs from r2_key_gif/r2_key_mp4 on every
# read, so this value is effectively unused once R2_* is configured there.
R2_PUBLIC_BASE_URL=https://unused.sectionlap.local
